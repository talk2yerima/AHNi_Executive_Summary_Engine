# .env.example
# Copy this file to .env and fill in your real values.
# NEVER commit .env to git — it contains secrets.

# ── DHIS2 connection (required) ────────────────────────────────────────────────
DHIS2_URL=https://dhis-hfr.ahnigeria.org/
DHIS2_USER=your_username
DHIS2_PASS=your_password

# ── Azure Blob Storage (required for targets + upload) ─────────────────────────
# Find the connection string in: Azure Portal → Storage Account → Access keys
AZURE_CONNECTION_STRING=DefaultEndpointsProtocol=https;AccountName=YOUR_ACCOUNT;AccountKey=YOUR_KEY;EndpointSuffix=core.windows.net
AZURE_CONTAINER_NAME=powerbi-datasource

# Blob name of the targets Excel file inside the container
AZURE_EXCEL_BLOB_NAME=target.xlsx

# ── Combined RADET source (TX_CURR, TX_PVLS, HTS_TST) ─────────────────────────
# Container holding daily combined RADET files
RADET_CONTAINER=combine-radets-xls
# Blob path pattern — {date} is replaced with YYYY-MM-DD
RADET_BLOB_PATTERN={date}/ACE-1_Combined_RADET-{date}.xlsx
